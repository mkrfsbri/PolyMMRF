# ═══════════════════════════════════════════════════════════════════════════════
# Polymarket MM Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# Polygon wallet private key (hex, no 0x prefix)
POLY_PRIVATE_KEY=your_private_key_here

# Polymarket CLOB API credentials (obtained via API key derivation from private key)
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_base64_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# Funder wallet address (the address that funds the CLOB account)
POLY_FUNDER_ADDRESS=0xYourWalletAddressHere

# Rust log level (overrides config.toml log_level)
RUST_LOG=info
